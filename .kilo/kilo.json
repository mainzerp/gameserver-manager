{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.38"
      ]
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  },
  "permission": {
    "websearch": "allow",
    "codesearch": "allow",
    "lsp": "allow",
    "semantic_search": "allow"
  },
  "commit_message": {
    "prompt": ""
  }
}
