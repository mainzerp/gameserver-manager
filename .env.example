# GameServer Manager - Environment Configuration
# Copy this file to .env and adjust values

# Debug mode (enables auto-reload and verbose logging)
GSM_DEBUG=true

# Web server
GSM_HOST=0.0.0.0
GSM_PORT=8443
GSM_TRUSTED_PROXY=0.0.0.0

# Database
# PostgreSQL credentials (MUST change before first deployment)
POSTGRES_DB=gameserver
POSTGRES_USER=gsm
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
# Database URL (uses the credentials above by default in docker-compose)
# PostgreSQL (default):
GSM_DATABASE_URL=postgresql+asyncpg://gsm:CHANGE_ME@db:5432/gameserver
# SQLite (alternative for simple setups):
# GSM_DATABASE_URL=sqlite+aiosqlite:///./data/gameserver.db
# MySQL:
# GSM_DATABASE_URL=mysql+aiomysql://gsm:changeme@localhost:3306/gameserver

# Directory where game servers are stored
# GSM_SERVERS_DIR=./servers

# SteamCMD Configuration
# GSM_STEAMCMD_PATH=/usr/games/steamcmd
GSM_STEAMCMD_AUTO_INSTALL=true
GSM_STEAMCMD_INSTALL_DIR=./data/steamcmd
GSM_STEAM_API_KEY=

# How often to check for mod updates (in minutes)
GSM_MOD_CHECK_INTERVAL_MINUTES=60

# Secret key for sessions (REQUIRED -- generate with command below)
# python -c "import secrets; print(secrets.token_hex(32))"
GSM_SECRET_KEY=change-me-in-production

# SSL
GSM_SSL_ENABLED=false
# GSM_SSL_CERTFILE=/path/to/cert.pem
# GSM_SSL_KEYFILE=/path/to/key.pem

# Monitoring
GSM_METRIC_INTERVAL_SECONDS=30
GSM_METRIC_RETENTION_DAYS=7

# Backups
GSM_MAX_BACKUPS_PER_SERVER=10

# Notifications
# GSM_DISCORD_WEBHOOK_URL=
# GSM_DISCORD_NOTIFY_EVENTS=start,stop,crash,backup

# Public Status Page
GSM_PUBLIC_STATUS_ENABLED=false

# Update Checker
GSM_UPDATE_CHECK_ENABLED=true
# GSM_UPDATE_REPO=owner/repo
GSM_UPDATE_CHECK_INTERVAL_HOURS=24

# SFTP Access
GSM_SFTP_ENABLED=false
GSM_SFTP_PORT=2222

# Docker Container Isolation
GSM_DOCKER_ISOLATION_ENABLED=false
# GSM_DOCKER_DEFAULT_IMAGE=eclipse-temurin:21-jre
# GSM_DOCKER_NETWORK_MODE=host

# Test stack (used with docker-compose.test.yml)
# GSM_HOST_PORT_TEST=8444
# Copy .env.example to .env.test and generate strong secrets for:
# GSM_SECRET_KEY
# POSTGRES_PASSWORD
